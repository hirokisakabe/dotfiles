# Keep Codex command approvals aligned with the Claude Code permissions posture:
# routine development commands are allowed, while publishing/merge operations
# still require an explicit prompt.

prefix_rule(
    pattern = ["git", "push"],
    decision = "prompt",
    justification = "Pushing branches or tags should remain an explicit user decision.",
)
prefix_rule(
    pattern = ["gh", "pr", "merge"],
    decision = "prompt",
    justification = "Merging pull requests should remain an explicit user decision.",
)
prefix_rule(
    pattern = ["wt", "merge"],
    decision = "prompt",
    justification = "Worktree merges should remain an explicit user decision.",
)

prefix_rule(pattern = ["find"], decision = "allow")
prefix_rule(pattern = ["rg"], decision = "allow")
prefix_rule(pattern = ["grep"], decision = "allow")
prefix_rule(pattern = ["ls"], decision = "allow")
prefix_rule(pattern = ["wc"], decision = "allow")
prefix_rule(pattern = ["cat"], decision = "allow")
prefix_rule(pattern = ["awk"], decision = "allow")
prefix_rule(pattern = ["tree"], decision = "allow")
prefix_rule(pattern = ["mkdir"], decision = "allow")
prefix_rule(pattern = ["kill"], decision = "allow")
prefix_rule(pattern = ["lsof"], decision = "allow")
prefix_rule(pattern = ["source"], decision = "allow")
prefix_rule(pattern = ["command", "-v"], decision = "allow")
prefix_rule(pattern = ["test"], decision = "allow")
prefix_rule(pattern = ["xargs"], decision = "allow")
prefix_rule(pattern = ["sleep"], decision = "allow")
prefix_rule(pattern = ["echo"], decision = "allow")
prefix_rule(pattern = ["env"], decision = "allow")
prefix_rule(pattern = ["md5"], decision = "allow")

prefix_rule(pattern = ["git"], decision = "allow")
prefix_rule(pattern = ["gh"], decision = "allow")
prefix_rule(pattern = ["make", "link"], decision = "allow")
prefix_rule(pattern = ["codex", "exec"], decision = "allow")

prefix_rule(pattern = ["node"], decision = "allow")
prefix_rule(pattern = ["npm"], decision = "allow")
prefix_rule(pattern = ["npx"], decision = "allow")
prefix_rule(pattern = ["pnpm"], decision = "allow")
prefix_rule(pattern = ["bun"], decision = "allow")
prefix_rule(pattern = ["copilot"], decision = "allow")
prefix_rule(pattern = ["uv"], decision = "allow")
prefix_rule(pattern = ["python3"], decision = "allow")
prefix_rule(pattern = ["pip3"], decision = "allow")
prefix_rule(pattern = ["mise", "exec"], decision = "allow")

prefix_rule(pattern = ["curl"], decision = "allow")
prefix_rule(pattern = ["agent-browser"], decision = "allow")

prefix_rule(pattern = ["terraform"], decision = "allow")
prefix_rule(pattern = ["tflint"], decision = "allow")
prefix_rule(pattern = ["docker"], decision = "allow")
prefix_rule(pattern = ["k6"], decision = "allow")
prefix_rule(pattern = ["actionlint"], decision = "allow")
prefix_rule(pattern = ["convert"], decision = "allow")
prefix_rule(pattern = ["unzip"], decision = "allow")
prefix_rule(pattern = ["pyftsubset"], decision = "allow")
