[user]
name = Hiroki SAKABE
email = hiroki.sakabe@icloud.com

[alias]
gg = "log --graph --pretty=oneline"
# stash -> デフォルトブランチに移動 -> pull -> 元ブランチ削除 -> stash pop
sdd = "!f() { CURRENT_BRANCH=$(git symbolic-ref --short HEAD); DEFAULT_BRANCH=$(git config default.branch); git stash; git checkout $DEFAULT_BRANCH; git pull; git branch -D $CURRENT_BRANCH; git stash pop; }; f"

[rebase]
autostash = true
abbreviateCommands = true
autosquash = true

[pull]
ff = only

[core]
excludesfile = ~/.gitignore_global
pager = delta

[interactive]
diffFilter = delta --color-only

[delta]
# Iceberg dark palette - https://github.com/cocopon/iceberg.vim
navigate = true
line-numbers = true
syntax-theme = base16
minus-style = syntax "#3c2a30"
minus-emph-style = syntax "#5e3a44"
plus-style = syntax "#293f3a"
plus-emph-style = syntax "#3a5a52"
zero-style = syntax
line-numbers-minus-style = "#e27878"
line-numbers-plus-style = "#b4be82"
line-numbers-left-style = "#6b7089"
line-numbers-right-style = "#6b7089"
line-numbers-zero-style = "#6b7089"
file-style = "#84a0c6" bold
file-decoration-style = "#6b7089" ul
hunk-header-style = "#a093c7" bold
hunk-header-decoration-style = "#6b7089" box

[merge]
conflictStyle = zdiff3

[push]
autoSetupRemote = true

[init]
defaultBranch = main

[default]
branch = main

[ghq]
root = ~/work

# GitAlias configuration
[include]
    path = ~/.git-extensions/gitalias.txt
