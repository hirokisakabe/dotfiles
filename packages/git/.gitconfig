[user]
name = Hiroki SAKABE
email = hiroki.sakabe@icloud.com

[alias]
gg = "log --graph --pretty=oneline"
# stash -> デフォルトブランチに移動 -> pull -> 元ブランチ削除 -> stash pop
sdd = "!f() { CURRENT_BRANCH=$(git symbolic-ref --short HEAD); DEFAULT_BRANCH=$(git config default.branch); git stash; git checkout $DEFAULT_BRANCH; git pull; git branch -D $CURRENT_BRANCH; git stash pop; }; f"

[rebase]
autostash = true
abbreviateCommands = true
autosquash = true

[pull]
ff = only

# Verify received objects; fetch/receive are explicit even though transfer is a fallback.
[transfer]
fsckObjects = true

[fetch]
fsckObjects = true

[receive]
fsckObjects = true

[core]
excludesfile = ~/.gitignore_global
pager = delta
hooksPath = ~/.git-hooks

[interactive]
diffFilter = delta --color-only

[delta]
# Frosted Aqua palette
navigate = true
line-numbers = true
syntax-theme = base16
minus-style = syntax "#f4dce2"
minus-emph-style = syntax "#ebc0ca"
plus-style = syntax "#dcefe7"
plus-emph-style = syntax "#b9dfd0"
zero-style = syntax
line-numbers-minus-style = "#b84f68"
line-numbers-plus-style = "#3f8969"
line-numbers-left-style = "#6d8496"
line-numbers-right-style = "#6d8496"
line-numbers-zero-style = "#6d8496"
file-style = "#4c87c7" bold
file-decoration-style = "#8abdd0" ul
hunk-header-style = "#8076b3" bold
hunk-header-decoration-style = "#8abdd0" box

[merge]
conflictStyle = zdiff3

[push]
autoSetupRemote = true

[init]
defaultBranch = main

[default]
branch = main

# GitAlias configuration
[include]
    path = ~/.git-extensions/gitalias.txt
[filter "lfs"]
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
